{
  "name": "material-icon-wizard",
  "version": "0.1.2",
  "description": "CLI to add Material Icons (or custom SVGs) to a project, normalized so their color follows CSS currentColor.",
  "keywords": [
    "material-icons",
    "material-design",
    "svg",
    "currentcolor",
    "icons",
    "cli"
  ],
  "license": "MIT",
  "homepage": "https://github.com/noxieee/material-icon-wizard#readme",
  "bugs": "https://github.com/noxieee/material-icon-wizard/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/noxieee/material-icon-wizard.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "bin": {
    "material-icon-wizard": "dist/cli.js",
    "icon-wizard": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "esbuild src/cli.js --bundle --platform=node --format=esm --target=node18 --outfile=dist/cli.js",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@material-icon-wizard/core": "*",
    "esbuild": "^0.28.1",
    "vitest": "^4.1.10"
  }
}
