{
  "name": "material-icon-wizard-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Take Material icon names (or custom SVGs), verify, normalize fill to currentColor, and export — CLI + web, one shared core.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.10.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.6"
  },
  "allowScripts": {
    "esbuild@0.28.1": true
  }
}
